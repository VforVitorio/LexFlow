# LexFlow frontend env

# FastAPI backend base URL. Used by the dev proxy (`/api` → this) and
# directly when VITE_API_URL is set without proxy.
VITE_API_URL=http://localhost:8000

# Use in-process mock data instead of hitting the API.
# Set to "false" once the FastAPI backend is wired up.
VITE_USE_MOCK=true

# Default chat model id (matches an entry in src/lib/models.ts).
VITE_DEFAULT_MODEL=claude-sonnet-4-5
