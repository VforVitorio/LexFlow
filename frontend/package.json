{
  "name": "lexflow-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LexFlow — Spanish legislation, alive and navigable. React + TS frontend.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "generate:api": "openapi-typescript http://localhost:8000/openapi.json -o src/api/schema.ts",
    "preview:ci": "vite preview --port 4173 --strictPort",
    "a11y": "start-server-and-test preview:ci http://localhost:4173 a11y:run",
    "a11y:run": "node scripts/a11y.mjs"
  },
  "dependencies": {
    "@reactour/tour": "^3.8.0",
    "@tanstack/react-query": "^5.101.0",
    "@types/opentype.js": "^1.3.10",
    "@xyflow/react": "^12.11.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "lucide-react": "^1.17.0",
    "opentype.js": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-2d": "^1.29.1",
    "react-i18next": "^15.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.27.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.49",
    "start-server-and-test": "^3.0.11",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
